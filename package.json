{
  "name": "tinytales-monorepo",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:main": "npm run dev --workspace=apps/main",
    "dev:admin": "npm run dev --workspace=apps/admin",
    "build:main": "npm run build --workspace=apps/main",
    "build:admin": "npm run build --workspace=apps/admin",
    "build": "npm run build:main && npm run build:admin",
    "db:generate": "npx prisma generate --schema=packages/db/prisma/schema.prisma",
    "db:push": "npx prisma db push --schema=packages/db/prisma/schema.prisma",
    "db:migrate": "npx prisma migrate dev --schema=packages/db/prisma/schema.prisma",
    "db:studio": "npx prisma studio --schema=packages/db/prisma/schema.prisma",
    "postinstall": "npm run db:generate"
  }
}